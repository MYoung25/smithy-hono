    "deploy": "npm -w @smithy-hono/deploy-cf run build >/dev/null 2>&1; cd deploy/cf-secure && node ../../packages/deploy-cf/dist/bin/deploy.js"
  },
  "devDependencies": {
    "wrangler": "^4.20.0"
  },
