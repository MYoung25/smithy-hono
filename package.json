{
  "name": "smithy-hono",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm -w @smithy-hono/security-core run build",
    "test": "npm -w @smithy-hono/security-core run test",
