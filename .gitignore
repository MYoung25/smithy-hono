# Gradle
.gradle/
build/

# TypeScript typecheck helpers
typecheck/generated/

# node_modules at every depth (root, packages/*, examples/*, typecheck).
# Reinstalled fresh by the build — never committed.
node_modules/

# Package build outputs. dist/ is rebuilt by `npm run build`/`prepare`; the packed
# tarball is the publish-accurate artifact consumers install as a REAL COPY
# (replaces the old source symlink, eliminating the hono version-skew). Both are
# regenerated by the Gradle/CI pack step before any consumer install — not committed.
packages/*/dist/
packages/*/*.tgz

# Gradle marker for the example vitest pass (build output).
examples/todo-api/.vitest-passed
examples/crud-api/.vitest-passed

# Vite build output for the demo UI (rebuilt by `npm run build`).
examples/crud-ui/dist/

# Wrangler local dev / miniflare state (local D1 sqlite, caches). Transient.
deploy/**/.wrangler/

# One-command secure deploy: rendered wrangler config, CLI state, the user's
# IdP secret, and the SPA build output — all regenerated / supplied per deploy.
deploy/cf-secure/wrangler.toml
deploy/cf-secure/.smithy-deploy/
deploy/cf-secure/deploy.secrets.json
examples/secure-ui/dist/

# Playwright MCP session artifacts (traces/snapshots). Transient — never committed.
.playwright-mcp/

# CDK synth output for the AWS deploy CLI (regenerated by `cdk synth`/`deploy`).
packages/deploy-aws/cdk.out/
