{
  "name": "@smithy-hono/deploy-cf",
  "version": "0.2.5",
  "type": "module",
  "description": "One-command Cloudflare Workers deploy for smithy-hono apps: given a domain, provisions the declared bindings (KV / Durable Objects / D1), generates + syncs secrets, renders wrangler config with a custom-domain route, builds the UI, and deploys — UI + API same-origin under an /api/* prefix. Config-driven via smithy-deploy.config.{mjs,json}; node-only CLI.",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "bin": {
    "smithy-hono-deploy": "./dist/bin/deploy.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "prepare": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src"
  },
  "dependencies": {
    "@smithy-hono/key-tool": "^0.2.5"
  },
  "peerDependencies": {
    "wrangler": ">=4.20.0"
  },
  "peerDependenciesMeta": {
    "wrangler": {
      "optional": true
    }
  },
  "devDependencies": {
    "@smithy-hono/key-tool": "^0.2.5",
    "@types/node": "^22.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MYoung25/smithy-hono.git",
    "directory": "packages/deploy-cf"
  }
}
