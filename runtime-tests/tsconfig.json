{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "types": [],
    "skipLibCheck": true
  },
  "include": ["generated/**/*.ts", "test/**/*.ts"],
  "exclude": ["generated/**/*.template.ts", "node_modules"]
}
